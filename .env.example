# ── Option A: Browser token (no admin needed) ──
# Extract from browser DevTools (see setup wizard for instructions)
# SLACK_TOKEN=xoxc-your-browser-token
# SLACK_COOKIE=xoxd-your-cookie-value

# ── Option B: Slack App token (needs admin approval) ──
# Get from: https://api.slack.com/apps → Your App → OAuth & Permissions
# SLACK_TOKEN=xoxp-your-app-token

SLACK_TOKEN=
SLACK_COOKIE=
